# Ollama Modelfile for MyLLM / Ramanujan-1B (GGUF)
# Build:  ollama create ramanujan-1b -f Modelfile
# Run:    ollama run ramanujan-1b "What is 2+2?"
#
FROM ./Ramanujan-1B-BF16.gguf

# Chat format must match training:  <|role|>\n{content}<|end|>\n ... <|assistant|>\n
TEMPLATE """{{ if .System }}<|system|>
{{ .System }}<|end|>
{{ end }}{{ if .Prompt }}<|user|>
{{ .Prompt }}<|end|>
{{ end }}<|assistant|>
{{ .Response }}<|end|>
"""

SYSTEM "You are a careful mathematical assistant. Show clear reasoning and give the final answer."

# Stop tokens: the model ends an assistant turn with <|end|> (also <eos>).
PARAMETER stop "<|end|>"
PARAMETER stop "<eos>"

# Sampling that matches the working HF setup (greedy/no-penalty makes this small
# base model loop and never emit <|end|>; the repeat penalty fixes that).
PARAMETER temperature 0.7
PARAMETER top_p 0.9
PARAMETER top_k 40
PARAMETER repeat_penalty 1.3
PARAMETER repeat_last_n 64
PARAMETER num_predict 256
